{
  "$schema": "http://json.schemastore.org/template",
  "author": "Jose Junior <almeidajr.vr@gmail.com>",
  "classifications": ["Kongroo", "Test", "Integration"],
  "identity": "Kongroo.Templates.IntegrationTests",
  "name": "Kongroo Integration Tests",
  "shortName": "kongroo-itest",
  "tags": { "language": "C#", "type": "project" },
  "sourceName": "Kongroo.SampleApp.IntegrationTests",
  "preferNameDirectory": true,
  "sources": [
    {
      "exclude": ["**/bin/**", "**/obj/**", ".template.config/**"]
    }
  ],
  "primaryOutputs": [{ "path": "Kongroo.SampleApp.IntegrationTests.csproj" }],
  "postActions": [
    {
      "id": "restore",
      "condition": "true",
      "description": "Restore NuGet packages",
      "manualInstructions": [{ "text": "Run 'dotnet restore'" }],
      "actionId": "210D431B-A78B-4D2F-B762-4ED3E3EA9025",
      "continueOnError": true
    },
    {
      "id": "add-to-sln",
      "condition": "true",
      "description": "Add project to solution",
      "manualInstructions": [{ "text": "Run 'dotnet sln add .'" }],
      "actionId": "AC1156F7-BB77-4DB8-B28F-24EEBCCA1E5C",
      "continueOnError": true
    }
  ]
}
