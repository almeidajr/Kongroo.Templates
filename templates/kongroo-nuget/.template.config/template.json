{
  "$schema": "http://json.schemastore.org/template",
  "author": "Jose Junior <almeidajr.vr@gmail.com>",
  "classifications": ["Kongroo", "Library", "NuGet"],
  "identity": "Kongroo.Templates.NuGet",
  "name": "Kongroo NuGet Package Library",
  "shortName": "kongroo-nuget",
  "tags": { "language": "C#", "type": "solution" },
  "sourceName": "Kongroo.SampleLib",
  "preferNameDirectory": true,
  "primaryOutputs": [{ "path": "Kongroo.SampleLib.slnx" }],
  "sources": [
    {
      "exclude": [
        "**/bin/**",
        "**/obj/**",
        "**/artifacts/**",
        "**/node_modules/**",
        "**/.vs/**",
        "**/TestResults/**",
        "**/*.user",
        ".template.config/**"
      ]
    }
  ],
  "postActions": [
    {
      "id": "restore",
      "condition": "true",
      "description": "Restore NuGet packages",
      "manualInstructions": [{ "text": "Run 'dotnet restore'" }],
      "actionId": "210D431B-A78B-4D2F-B762-4ED3E3EA9025",
      "continueOnError": true
    }
  ]
}
