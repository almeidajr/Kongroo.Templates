{
  "$schema": "http://json.schemastore.org/template",
  "author": "Jose Junior <almeidajr.vr@gmail.com>",
  "classifications": ["Kongroo", "Web", "Solution", "API"],
  "identity": "Kongroo.Templates.Solution",
  "name": "Kongroo Solution",
  "shortName": "kongroo-sln",
  "tags": { "language": "C#", "type": "solution" },
  "sourceName": "SampleApp",
  "preferNameDirectory": true,
  "symbols": {
    "observability": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "true",
      "description": "Include OpenTelemetry tracing and metrics."
    },
    "integration-tests": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "true",
      "description": "Include the integration-test project."
    }
  },
  "sources": [
    {
      "exclude": [
        "**/bin/**",
        "**/obj/**",
        "**/node_modules/**",
        "**/.vs/**",
        "**/TestResults/**",
        "**/*.user"
      ],
      "modifiers": [
        {
          "condition": "(!integration-tests)",
          "exclude": ["test/Kongroo.SampleApp.IntegrationTests/**"]
        }
      ]
    }
  ],
  "primaryOutputs": [{ "path": "Kongroo.SampleApp.slnx" }],
  "postActions": [
    {
      "id": "restore",
      "condition": "true",
      "description": "Restore NuGet packages",
      "manualInstructions": [{ "text": "Run 'dotnet restore'" }],
      "actionId": "210D431B-A78B-4D2F-B762-4ED3E3EA9025",
      "continueOnError": true
    }
  ]
}
